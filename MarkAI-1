import pandas as pd
from sklearn.cluster import KMeans
from fastapi import HTTPException

def analyze_disaster_data(file_path: str):
    try:
        data = pd.read_csv(file_path)
        
        # تحليل العنقدة لتحديد المناطق المتأثرة
